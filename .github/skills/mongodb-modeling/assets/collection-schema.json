{
  "collection": "products",
  "indexes": [
    {
      "name": "sku_unique",
      "keys": { "sku": 1 },
      "options": { "unique": true }
    },
    {
      "name": "category_status",
      "keys": { "category": 1, "status": 1 },
      "options": { "background": true }
    },
    {
      "name": "createdAt_desc",
      "keys": { "createdAt": -1 },
      "options": { "name": "idx_created_recent" }
    },
    {
      "name": "search_compound",
      "keys": { "name": "text", "description": "text" }
    }
  ],
  "validation": {
    "$jsonSchema": {
      "bsonType": "object",
      "required": ["name", "sku", "price", "stock"],
      "properties": {
        "_id": { "bsonType": "objectId" },
        "name": { "bsonType": "string", "minLength": 1 },
        "sku": { "bsonType": "string", "pattern": "^[A-Z0-9-]+$" },
        "price": { "bsonType": "decimal", "minimum": 0 },
        "stock": { "bsonType": "int", "minimum": 0 }
      }
    }
  }
}
