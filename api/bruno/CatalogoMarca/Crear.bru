meta {
  name: Crear
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/catalogomarca
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "nombre": "Apple",
    "imagen": null,
    "activa": true
  }
}

script:post-response {
  if (res.body.code === "0") {
    bru.setVar("catalogoMarcaId", res.body.data.id);
  }
}
