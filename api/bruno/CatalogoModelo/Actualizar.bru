meta {
  name: Actualizar
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/api/catalogomodelo/{{catalogoModeloId}}
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "nombre": "iPhone 15 Pro Max",
    "idMarca": "{{catalogoMarcaId}}",
    "activo": true
  }
}
