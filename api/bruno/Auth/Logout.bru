meta {
  name: Logout
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/auth/logout
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "refreshToken": "{{refreshToken}}"
  }
}

script:post-response {
  if (res.body.code === "0") {
    bru.setVar("accessToken", "");
    bru.setVar("refreshToken", "");
  }
}
