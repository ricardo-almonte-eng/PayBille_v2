{
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "paybille_v2"
  },
  "Jwt": {
    "SecretKey": "CHANGE_ME_to_a_secure_random_string_at_least_32_chars",
    "Issuer": "paybille-api",
    "Audience": "paybille-client",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Imagenes": {
    "DirectorioBase": "uploads",
    "TamanoMaximoBytes": 5242880,
    "TiposPermitidos": [ "image/jpeg", "image/png", "image/webp", "image/gif" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
